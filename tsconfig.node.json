{
	"compilerOptions": {
		"target": "ES2023",
		"lib": ["ES2023", "DOM"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"rootDir": "./src",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"types": ["node"]
	},
	"include": [
		"src/cli.ts",
		"src/index.ts",
		"src/mcp-server.ts",
		"src/lib/**/*"
	],
	"exclude": [
		"src/components/**/*",
		"src/App.tsx",
		"src/main.tsx",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"dist/**/*",
		"node_modules/**/*"
	]
}
